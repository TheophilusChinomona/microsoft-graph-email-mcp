# Microsoft Graph Email MCP Server -- Environment Variables
#
# Setup:
# 1. Go to https://portal.azure.com -> App registrations -> New registration
# 2. Name: "Hermes Email", Redirect URI: Web -> http://localhost:8721/callback
# 3. Copy Application (client) ID -> MS_CLIENT_ID
# 4. Certificates & secrets -> New client secret -> copy Value -> MS_CLIENT_SECRET
# 5. API permissions -> Add -> Microsoft Graph -> Delegated:
#    Mail.Read, Mail.ReadWrite, Mail.Send, User.Read, offline_access
# 6. Grant admin consent

MS_TENANT_ID=common
MS_CLIENT_ID=your-client-id-here
MS_CLIENT_SECRET=your-client-secret-here
MS_REDIRECT_URI=http://localhost:8721/callback

# Optional
# GRAPH_MAX_ATTACHMENT_SIZE=10485760
# GRAPH_RATE_LIMIT_RETRIES=3
